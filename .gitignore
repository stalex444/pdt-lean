/.lake

# Blueprint build outputs (generated by `leanblueprint pdf` / `leanblueprint web`)
/blueprint/web/
/blueprint/print/
/blueprint/lean_decls

# LaTeX / plasTeX auxiliary files left in blueprint/src by latexmk and xelatex
/blueprint/src/*.aux
/blueprint/src/*.bbl
/blueprint/src/*.blg
/blueprint/src/*.fdb_latexmk
/blueprint/src/*.fls
/blueprint/src/*.log
/blueprint/src/*.out
/blueprint/src/*.synctex.gz
/blueprint/src/*.toc
/blueprint/src/*.paux
/blueprint/src/*.pauxx
